# ===== Banco de dados =====
# Quando rodando local sem docker: postgres://postgres:postgres@localhost:5432/cyberguard
# Quando rodando via docker compose: postgres://postgres:postgres@db:5432/cyberguard
DATABASE_URL="postgres://postgres:postgres@localhost:5432/cyberguard"

# ===== Auth (JWT) =====
# Gere com: openssl rand -base64 32
JWT_SECRET="troque-este-segredo-por-uma-string-longa-e-aleatoria"

# ===== App =====
NEXT_PUBLIC_APP_NAME="CyberGuard"
NODE_ENV="development"
