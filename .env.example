# Copie este arquivo para .env e preencha com os valores reais
# NUNCA comite o .env com senhas reais no git

# ===== Banco de dados =====
# Dev local sem Docker: postgres://postgres:SENHA@localhost:5432/cyberguard
# Via docker compose: variável DATABASE_URL é montada automaticamente no compose
DATABASE_URL="postgres://postgres:TROQUE_AQUI@localhost:5432/cyberguard"

# Senha do PostgreSQL — usada pelo docker-compose.yml
# Gere uma forte: openssl rand -base64 32
POSTGRES_PASSWORD=TROQUE_AQUI

# ===== Auth (JWT) =====
# Gere com: openssl rand -base64 48
JWT_SECRET=TROQUE_AQUI

# ===== Bind do Docker (produção) =====
# IP Tailscale do VPS em produção (ex: 100.79.80.27)
# Em dev local, use 127.0.0.1
BIND_HOST=127.0.0.1

# ===== App =====
NEXT_PUBLIC_APP_NAME="CyberGuard"
NODE_ENV="development"
